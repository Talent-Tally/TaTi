# =============================================================================
# Copie ce fichier en `.env` et adapte les valeurs.
# Le `.env` est ignoré par git (cf. .gitignore).
# =============================================================================

# --- Postgres local (utilisé par docker compose) -----------------------------
POSTGRES_USER=tati
POSTGRES_PASSWORD=tati_dev_password
POSTGRES_DB=tati
POSTGRES_PORT=5432

# --- Distribution docker-compose.dist.yml (images GHCR, sans clone) ----------
# Proprietaire GitHub en minuscules (ex. jeffsouop). A adapter si fork.
TATI_IMAGE_REGISTRY=ghcr.io/jeffsouop
# Tag aligne sur la release GitHub (ex. v0.2.0) ou "latest" apres une release.
TATI_IMAGE_TAG=latest
# Port public de l app en mode image prod (docker-compose.dist.yml)
APP_PORT=3000
# Repertoire hote monte dans mcp-filesystem (mode dist ; defaut = repertoire du compose)
# MCP_FILESYSTEM_HOST_PATH=/chemin/vers/donnees

# --- App : URL de connexion à la DB (consommée par le serveur SSR) -----------
# En local hors Docker :
#   DATABASE_URL=postgres://tati:tati_dev_password@localhost:5432/tati
# Dans Docker, c'est déjà injecté via docker-compose.yml.
DATABASE_URL=postgres://tati:tati_dev_password@localhost:5432/tati

# --- Auth locale (multi-utilisateur) ----------------------------------------
# Active l'ecran de login par defaut (recommande pour toute installation).
TATI_AUTH_REQUIRED=true
# Duree de session login en jours.
TATI_SESSION_TTL_DAYS=30

# --- Pont MCP OpenMetadata ---------------------------------------------------
OPENMETADATA_URL=http://host.docker.internal:8585
OPENMETADATA_JWT=
# false par defaut: lecture seule. true => autorise patch metadata.
OPENMETADATA_ALLOW_MUTATIONS=false
# Garde-fou ecriture OpenMetadata: tools write exigeront confirm=<valeur>
OPENMETADATA_WRITE_CONFIRM_TOKEN=CONFIRM_OM

# --- Pont MCP PostgreSQL -----------------------------------------------------
# URL PostgreSQL consommée par le serveur MCP Postgres.
# Par défaut, il pointe vers le Postgres local du compose.
MCP_POSTGRES_DATABASE_URL=postgres://tati:tati_dev_password@postgres:5432/tati
# Port exposé du serveur MCP Postgres (URL TaTi: http://localhost:<port>/mcp)
MCP_POSTGRES_PORT=8002
# Mode sécurité du MCP Postgres:
# - true  => lecture seule (SELECT/SHOW/EXPLAIN)
# - false => autorise aussi INSERT/UPDATE/DELETE/DDL
MCP_POSTGRES_READ_ONLY=false

# --- Pont MCP PDF ------------------------------------------------------------
# Port exposé pour le serveur MCP PDF
MCP_PDF_PORT=8003
# Base URL publique utilisée dans les liens de téléchargement retournés
MCP_PDF_PUBLIC_BASE_URL=http://localhost:8003

# --- Pont MCP Notion ---------------------------------------------------------
# Token d'intégration Notion (format: secret_...)
MCP_NOTION_TOKEN=
MCP_NOTION_PORT=8004

# --- Pont MCP Slack ----------------------------------------------------------
# Bot token Slack (format: xoxb-...)
MCP_SLACK_BOT_TOKEN=
# Team ID Slack (format: T...)
MCP_SLACK_TEAM_ID=
# Optionnel: restreint aux channels autorisés, séparés par des virgules
MCP_SLACK_CHANNEL_IDS=
MCP_SLACK_PORT=8006

# --- Pont MCP Discord --------------------------------------------------------
# Bot token Discord (bot token de l'application Discord Developer Portal)
MCP_DISCORD_BOT_TOKEN=
# Guild (server) ID Discord
MCP_DISCORD_GUILD_ID=
# Optionnel: restreint aux channels autorisés, séparés par des virgules
MCP_DISCORD_CHANNEL_IDS=
MCP_DISCORD_PORT=8010

# --- Pont MCP Filesystem -----------------------------------------------------
# Racine autorisée pour les opérations fichiers du bridge
MCP_FILESYSTEM_ROOT=/workspace
MCP_FILESYSTEM_PORT=8011

# --- Pont MCP AWS ------------------------------------------------------------
# Credentials: soit profile (AWS_PROFILE), soit ACCESS_KEY/SECRET_KEY.
AWS_REGION=eu-west-3
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
MCP_AWS_PORT=8012

# --- Pont MCP Azure ----------------------------------------------------------
# Option A: Service Principal
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Option B: access token ARM deja genere
AZURE_ACCESS_TOKEN=
MCP_AZURE_PORT=8013

# --- Pont MCP GCP ------------------------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=europe-west1
# JSON complet d'un service account (escape sur une seule ligne)
GCP_SERVICE_ACCOUNT_JSON=
MCP_GCP_PORT=8014

# --- Pont MCP Email (SMTP) ---------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
# Optionnel: restreindre les destinataires autorisés (emails séparés par virgule)
SMTP_ALLOWED_RECIPIENTS=
MCP_EMAIL_PORT=8015

# --- Pont MCP Dagster --------------------------------------------------------
DAGSTER_GRAPHQL_URL=http://host.docker.internal:3000/graphql
DAGSTER_API_TOKEN=
# false par défaut: lecture seule. true => autorise launch/terminate run.
DAGSTER_ALLOW_MUTATIONS=false
MCP_DAGSTER_PORT=8016

# --- Pont MCP Apache Airflow --------------------------------------------------
# URL du serveur web Airflow (sans chemin /api/v1 ; le pont l’ajoute).
AIRFLOW_BASE_URL=http://host.docker.internal:8080
# Auth recommandée : utilisateur / mot de passe du compte Airflow (Basic).
AIRFLOW_USERNAME=
AIRFLOW_PASSWORD=
# Alternative : jeton Bearer si votre déploiement l’expose (sinon laisser vide).
AIRFLOW_API_TOKEN=
# false par défaut : lecture seule (liste DAGs, runs…). true => trigger run + pause DAG.
AIRFLOW_ALLOW_MUTATIONS=false
# Mettre false uniquement si certificat TLS auto-signé sur HTTPS.
AIRFLOW_SSL_VERIFY=true
MCP_AIRFLOW_PORT=8017

# --- Pont MCP dbt Cloud (Discovery API GraphQL) -------------------------------
# URL exacte : Account settings → Access URLs (ex. https://<prefix>.metadata.us1.dbt.com/graphql)
DBT_CLOUD_DISCOVERY_URL=
# Jeton de service dbt Cloud avec accès Metadata / Discovery (recommandé : scope minimal).
DBT_CLOUD_TOKEN=
# ID d’environnement dbt Cloud (pour dbt_list_models / dbt_list_sources sans argument).
DBT_CLOUD_ENVIRONMENT_ID=
# false seulement si certificat TLS auto-signé vers l’endpoint Discovery.
DBT_SSL_VERIFY=true
MCP_DBT_PORT=8018

# --- Pont MCP dbt Core (CLI sur projet monté) ---------------------------------
# Répertoire hôte du projet dbt (dbt_project.yml) monté sur /workspace dans le conteneur.
DBT_CORE_HOST_PROJECT=./dbt-core-project
# Chemin projet dans le conteneur (doit correspondre au point de montage).
DBT_CORE_PROJECT_DIR=/workspace
# Optionnel : dossier profiles.yml dans le conteneur (monter un volume ou ~/.dbt si besoin).
DBT_PROFILES_DIR=
# Optionnel : --target du profile dbt.
DBT_CORE_TARGET=
# false par défaut : parse/ls/compile/manifest uniquement. true => deps/run/test/build.
DBT_ALLOW_MUTATIONS=false
MCP_DBT_CORE_PORT=8019

# --- MCP GitHub / GitLab (bridges locaux optionnels) -------------------------
# Tokens pour les services docker mcp-github / mcp-gitlab.
MCP_GITHUB_TOKEN=
MCP_GITLAB_TOKEN=
# Optionnel (legacy): URL MCP explicite si ta config/outillage la reference encore.
MCP_GITHUB_MCP_URL=http://mcp-github:8007/mcp
MCP_GITLAB_MCP_URL=http://mcp-gitlab:8008/mcp
MCP_GITHUB_PORT=8007
MCP_GITLAB_PORT=8008
# Optionnel pour GitLab self-hosted
MCP_GITLAB_URL=https://gitlab.com
# Garde-fou ecriture GitHub/GitLab: tools write exigeront confirm=<valeur>
MCP_WRITE_CONFIRM_TOKEN=CONFIRM

# --- MCP Elasticsearch (streamable-http) -------------------------------------
# Caution: ce serveur est deprecie en faveur de l'Agent Builder MCP endpoint
# (Elastic 9.2+ / Serverless). Voir doc Elastic.
MCP_ELASTICSEARCH_URL=
MCP_ELASTICSEARCH_API_KEY=
# Alternative a la cle API:
MCP_ELASTICSEARCH_USERNAME=
MCP_ELASTICSEARCH_PASSWORD=
MCP_ELASTICSEARCH_SSL_SKIP_VERIFY=false
MCP_ELASTICSEARCH_PORT=8009

# --- MCP Grafana (serveur officiel) ------------------------------------------
# URL Grafana (self-hosted: http://host.docker.internal:3000, cloud: https://xxx.grafana.net)
MCP_GRAFANA_URL=
# Token Service Account Grafana (recommande)
MCP_GRAFANA_SERVICE_ACCOUNT_TOKEN=
# Optionnel: org id Grafana si multi-org
MCP_GRAFANA_ORG_ID=
MCP_GRAFANA_PORT=8020

# --- MCP Prometheus -----------------------------------------------------------
# URL Prometheus (ex: http://host.docker.internal:9090)
MCP_PROMETHEUS_URL=
# true par defaut. Mettre false si certif auto-signe.
MCP_PROMETHEUS_SSL_VERIFY=true
# Auth optionnelle
MCP_PROMETHEUS_USERNAME=
MCP_PROMETHEUS_PASSWORD=
MCP_PROMETHEUS_TOKEN=
MCP_PROMETHEUS_PORT=8021

# --- MCP Datadog (serveur MCP distant officiel) ------------------------------
# US1: https://mcp.datadoghq.com/api/unstable/mcp-server/mcp
# EU : https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp
# Optionnel toolsets: ?toolsets=core,synthetics,software-delivery ou ?toolsets=all
MCP_DATADOG_MCP_URL=https://mcp.datadoghq.com/api/unstable/mcp-server/mcp
MCP_DATADOG_API_KEY=
MCP_DATADOG_APPLICATION_KEY=

# --- MCP Moodle (plugin natif Moodle) ----------------------------------------
# Endpoint MCP natif Moodle:
# https://<ton-moodle>/webservice/mcp/server.php
MCP_MOODLE_MCP_URL=
# Token du service externe Moodle (utiliser en header Authorization: Bearer <token>)
MCP_MOODLE_TOKEN=

# --- MCP Google Workspace (serveurs MCP distants officiels) ------------------
# Endpoints MCP distants:
MCP_GMAIL_MCP_URL=https://gmailmcp.googleapis.com/mcp/v1
MCP_GOOGLE_CALENDAR_MCP_URL=https://calendarmcp.googleapis.com/mcp/v1
# Projet GCP ou les APIs MCP Google sont activees
GOOGLE_CLOUD_PROJECT_ID=
# Optionnel: credentials OAuth client (utile pour certains flows/outils externes)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Token OAuth/Access token pour header Authorization Bearer (si utilise via headers MCP)
GOOGLE_OAUTH_ACCESS_TOKEN=
